## syntax=docker/dockerfile:1

# Useful hints used here:
# https://adambrodziak.pl/dockerfile-good-practices-for-node-and-npm

# Get Caddy version externally, e.g. 2.11
# We need to supply a default as we can't mandate this is set
ARG CADDY_VERSION=nonesuch

# Get Node version externally, e.g. 22.4.1
# We need to supply a default as we can't mandate this is set
ARG NODE_VERSION=nonesuch

# Use this node image for building
FROM node:${NODE_VERSION}-alpine AS build

# Umami URL, and Maptiler, Glitchtip and MixPanel API keys.
ARG UMAMI_URL=https://umami.digitalcommons.coop/script.js
ARG UMAMI_ID
ARG MAPTILER_API_KEY
ARG GLITCHTIP_KEY
ARG MIXPANEL_TOKEN # optional
ARG MIXPANEL_SESSION_RECORDING_PERCENT # optional

# API and WWW base URLs
ARG API_URL=/api
ARG BASE_URL=/

# Copy source in. Note, .dockerignore should exclude node_modules and dist dirs
COPY .  /srv/src

# Required variables
ENV VITE_MAPTILER_API_KEY=${MAPTILER_API_KEY?}
ENV VITE_UMAMI_URL=${UMAMI_URL?}
ENV VITE_UMAMI_ID=${UMAMI_ID?}
ENV VITE_GLITCHTIP_KEY=${GLITCHTIP_KEY?}

# Optional variables
ENV VITE_MIXPANEL_TOKEN=${MIXPANEL_TOKEN}
ENV VITE_MIXPANEL_SESSION_RECORDING_PERCENT=${MIXPANEL_SESSION_RECORDING_PERCENT}

# Optional variables with defaults
ENV VITE_API_URL=${API_URL?}
ENV VITE_BASE_URL=${BASE_URL?}


# Download dependencies as a separate step to take advantage of Docker's caching.
# Use a cache mount to /root/.npm to speed up subsequent builds.
# Use a bind mount to access the source code
RUN --mount=type=cache,target=/root/.npm <<SCRIPT
set -e

# Git is needed for the build info
apk add git

cd /srv/src
npm ci
cd apps/front-end/
npm run build

SCRIPT


# This is the image we'll keep
FROM caddy:${CADDY_VERSION}-alpine

# We need to know the hostname, let's make that explicit by declaring an arg
ARG CADDY_HOSTNAME


WORKDIR /usr/share/caddy/

# All the relevant ENV variables needed by the front end are set when
# the application is built, and baked in.

# Copy the built application files from the build image into this image.
COPY --from=build /srv/src/apps/front-end/dist/ .

RUN <<SCRIPT
set -e

# Generate the Caddy config into the image.
#
# This Caddyfile config reverse-proxying the API, and assumes that
# should be from http://${CADDY_HOSTNAME}/api/* -> to
# http://back-end:3000/
#
cat >/etc/caddy/Caddyfile <<EOF
# Autogenerated
${CADDY_HOSTNAME?}:80

file_server

reverse_proxy /api/* http://back-end:3000
EOF
SCRIPT
